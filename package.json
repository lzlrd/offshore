{
    "name": "offshore",
    "version": "0.1.0",
    "description": "An MCP server which allows you to utilise an abliterated model locally for questions that Claude will not answer.",
    "type": "module",
    "bin": {
        "offshore": "dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsc --watch",
        "typecheck": "tsc --noEmit",
        "pretest": "tsc",
        "test": "node --test"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "abliterated",
        "uncensored",
        "claude-bypass",
        "ollama",
        "local-llm"
    ],
    "license": "PolyForm-Noncommercial-1.0.0",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.0",
        "smol-toml": "^1.6.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=18"
    }
}